{
  "openrpc": "1.2.1",
  "info": {
    "title": "gql-mcp",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "SearchProducts",
      "description": "Search for products by keyword, category, or other criteria.",
      "params": [
        {
          "name": "query",
          "required": true,
          "schema": {
            "type": "string",
            "description": "Search keyword — product name, description, or barcode"
          }
        },
        {
          "name": "page",
          "required": false,
          "schema": {
            "type": "integer",
            "description": "The `Int` scalar type represents non-fractional signed whole numeric values. Int can represent values between -(2^31) and 2^31 - 1."
          }
        },
        {
          "name": "count",
          "required": false,
          "schema": {
            "type": "integer",
            "description": "Maximum number of results to return (default: 24, max: 50)"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object"
        }
      }
    },
    {
      "name": "GetProduct",
      "description": "Fetch a single product by TPNC code.",
      "params": [
        {
          "name": "tpnc",
          "required": false,
          "schema": {
            "type": "string",
            "description": "The `String` scalar type represents textual data, represented as UTF-8 character sequences. The String type is most often used by GraphQL to represent free-form human-readable text."
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object"
        }
      }
    },
    {
      "name": "UpdateItems",
      "description": "Add, update, or remove items in the customer's Tesco basket.",
      "params": [
        {
          "name": "items",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "identifier": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    }
                  },
                  "required": [],
                  "description": "Identifier is TSAYS related field"
                },
                "itemAttributes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "key",
                      "value"
                    ]
                  },
                  "description": "itemAttributes is used in TSAYS . Item attributes like batchOrLotNumber, expiryDate, serialNumber, consumerProductVariant. Often these attributes will come from embedded barcodes, like GS1"
                },
                "barcode": {
                  "type": "string"
                },
                "uuid": {
                  "type": "string"
                },
                "value": {
                  "type": "number"
                },
                "oldValue": {
                  "type": "number"
                },
                "newValue": {
                  "type": "number"
                },
                "adjustment": {
                  "type": "boolean"
                },
                "unitChoice": {
                  "type": "string"
                },
                "unitCost": {
                  "type": "number"
                },
                "newUnitChoice": {
                  "type": "string"
                },
                "gtin": {
                  "type": "string"
                },
                "schemeId": {
                  "type": "string"
                },
                "oldUnitChoice": {
                  "type": "string"
                },
                "pickerNote": {
                  "type": "string"
                },
                "substitutionOption": {
                  "type": "string",
                  "enum": [
                    "DoNotSubstitute",
                    "LookForThisItemInstead",
                    "FindSuitableAlternative"
                  ]
                },
                "catchWeight": {
                  "type": "number"
                },
                "ean": {
                  "type": "string"
                },
                "totalCost": {
                  "type": "number"
                },
                "image": {
                  "type": "string"
                },
                "sellerId": {
                  "type": "string"
                }
              },
              "required": []
            }
          }
        },
        {
          "name": "basketContexts",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "ONLINE_REWARDS",
                    "PICKNGO",
                    "GROCERY",
                    "MARKETPLACE",
                    "FNF"
                  ]
                },
                "primary": {
                  "type": "boolean"
                },
                "bookDefaultFulfilmentOptionIfNotBooked": {
                  "type": "boolean"
                },
                "addressId": {
                  "type": "string"
                }
              },
              "required": []
            }
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object"
        }
      }
    },
    {
      "name": "batchSearchProducts",
      "description": "Search for multiple products using parallel execution",
      "params": [
        {
          "name": "searchTerms",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of keywords to search for"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object"
        }
      }
    },
    {
      "name": "enrichedProductSearch",
      "description": "Search products and enrich with data from external pricing API",
      "params": [
        {
          "name": "query",
          "required": true,
          "schema": {
            "type": "string",
            "description": "Product search query"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object"
        }
      }
    }
  ]
}